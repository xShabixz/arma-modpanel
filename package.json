{
  "name": "ptero-mod-manager",
  "version": "0.1.0",
  "description": "Arma Reforger mod manager service with dependency checks for Pterodactyl",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "ptero:bulk": "node scripts/ptero-bulk-upsert.mjs"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "adm-zip": "^0.5.16",
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
